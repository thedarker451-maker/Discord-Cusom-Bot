# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here
DISCORD_BOT_TOKEN=your_bot_token_here

# Redis Configuration (Docker usa redis://redis:6379, Render déjalo en false)
REDIS_URL=redis://redis:6379
REDIS_DB=true

# Node Environment
NODE_ENV=production

# Web Server
PORT=3000
LEADERBOARD_ENABLED=true

# AI Configuration
# Proveedores: openai, mistral, gemini, deepseek, groq, huggingface, together, anthropic, opencode, litellm
PROVIDER=mistral
API_KEY=your_api_key_here
AI_MODEL=

# Para LiteLLM/Proxy personalizado:
# AI_BASE_URL=https://your-proxy.com

# Telemetry
TELEMETRY_STATE=false

# Prefix
PREFIX=!

# Webhooks (opcional)
LOG_WEBHOOK=
ERROR_WEBHOOK=

# Public URL
PUBLIC_URL=

# Auto-update (solo VPS, no Render)
AUTO_UPDATE=true
